# Copie este arquivo para ".env" e preencha com valores reais antes de rodar.

# Banco de dados (Postgres) - use Supabase, Neon, Railway ou um Postgres local
DATABASE_URL=postgres://usuario:senha@localhost:5432/laudos_engenharia

# Autenticacao
JWT_SECRET=troque-por-uma-string-aleatoria-longa

# API da IA - crie sua chave em https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# D4Sign - preencher apos fechar contrato e obter credenciais no painel deles
D4SIGN_BASE_URL=https://sandbox.d4sign.com.br/api/v1
D4SIGN_API_TOKEN=
D4SIGN_CRYPT_KEY=
D4SIGN_SAFE_ID=

# Porta do servidor
PORT=3000

# URL pública do seu app (usada nos redirecionamentos pós-checkout)
APP_URL=https://seu-app.exemplo.com

# Stripe - crie sua conta em https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
